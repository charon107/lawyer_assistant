# lpa_review_app Environment Variables

# === Project ===
PROJECT_NAME=lpa_review_app
DEBUG=true
ENVIRONMENT=local
TIMEZONE=UTC  # IANA timezone: UTC, Europe/Warsaw, America/New_York
MODELS_CACHE_DIR=./models_cache

# === SQLite ===
SQLITE_PATH=./data/lpa_review_app.db

# === JWT Auth ===
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# === API Key Auth ===
API_KEY=change-me-in-production
API_KEY_HEADER=X-API-Key


# === AI Agent (pydantic_ai) ===
# Provider: "openai" (OpenAI-compatible) or "anthropic" (Claude)
LLM_PROVIDER=openai
AI_MODEL=              # e.g. deepseek-v4-pro, MiMo, gpt-4o, etc.
OPENAI_API_KEY=                  # API key for your LLM provider
ANTHROPIC_API_KEY=               # Anthropic Claude models
LLM_BASE_URL=                    # Custom base URL for OpenAI-compatible APIs
AI_TEMPERATURE=0.7

# === LPA Review ===
# Uses the same LLM config as above (OPENAI_API_KEY + LLM_BASE_URL + AI_MODEL)
# Or configure per-user LLM in the app settings page

# === Law RAG (Qdrant) ===
QDRANT_URL=http://localhost:6333  # Use http://qdrant:6333 inside Docker
QDRANT_API_KEY=                   # Optional Qdrant API key
EMBEDDING_MODEL_NAME=BAAI/bge-base-zh-v1.5
EMBEDDING_CACHE_DIR=              # Custom cache dir for embedding model
LAW_SEARCH_TOP_K=5
REDIS_URL=redis://localhost:6379/0  # Use redis://redis:6379/0 inside Docker

# === CORS ===
# JSON list of allowed origins (default: localhost:3000, localhost:8080)
# Note: "*" is blocked in production - specify explicit origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
